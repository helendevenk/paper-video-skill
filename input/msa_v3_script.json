      "notes": "",
      "visual": {
        "language": "python",
        "code": "# MSA Router Algorithm\ndef msa_router(Q, K_compressed, k):\n    # Step 1: Router scoring\n    scores = einsum(\"bhqd,bkd->bhqk\", Q_r, K_r)\n    scores = scores.mean(dim=1)  # mean over heads\n    scores = scores.max(dim=1).values  # max over tokens\n\n    # Step 2: Top-k selection\n    top_k_idx = scores.topk(k, dim=-1).indices\n\n    # Step 3: Context assembly\n    selected_kv = gather(KV_compressed, top_k_idx)\n    context = concat(selected_kv, local_kv)\n    return context",
        "highlightLines": [
